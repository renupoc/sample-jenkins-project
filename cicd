pipeline {
    agent any

    stage('Checkout') {
    steps {
        git branch: 'main',
            url: 'https://github.com/renupoc/sample-jenkins-project.git'
    }
}

        stage('Build & Test') {
            steps {
                sh 'mvn clean test'
            }
        }
    }

    post {
        always {
            junit '**/target/surefire-reports/*.xml'
        }
    }
}
